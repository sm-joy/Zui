---
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-owning-memory,
  cppcoreguidelines-special-member-functions,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-default-member-init,
  modernize-loop-convert,
  performance-*,
  readability-const-return-type,
  readability-qualified-auto,
  readability-avoid-const-params-in-decls,
  readability-identifier-naming,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-optin.performance.Padding

WarningsAsErrors: "bugprone-*,clang-analyzer-*"

HeaderFilterRegex: "^((?!third_party|vendor|external|generated).)*$"

FormatStyle: file

CheckOptions:
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: true

  - key: modernize-use-default-member-init.UseAssignment
    value: true

  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: false


  # Classes and Structs → PascalCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase

  # Interfaces / Abstract classes → IPascalCase
  - key: readability-identifier-naming.AbstractClassPrefix
    value: I

  # Functions and Methods → PascalCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.MethodCase
    value: CamelCase

  # Public member variables → PascalCase
  - key: readability-identifier-naming.PublicMemberCase
    value: CamelCase

  # Private and Protected member variables → m_ prefix + camelCase
  - key: readability-identifier-naming.PrivateMemberCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_
  - key: readability-identifier-naming.ProtectedMemberCase
    value: camelBack
  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: m_

  # Local variables → camelCase
  - key: readability-identifier-naming.LocalVariableCase
    value: camelBack

  # Parameters → camelCase
  - key: readability-identifier-naming.ParameterCase
    value: camelBack

  # Constants → ALL_CAPS
  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.ConstexprVariableCase
    value: UPPER_CASE

  # Enums → ALL_CAPS
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE

  # Namespaces → lowercase
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Template parameters → PascalCase
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.TemplateTemplateParameterCase
    value: CamelCase
