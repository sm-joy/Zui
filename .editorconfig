root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,lua}]
indent_style = space
indent_size  = 4

[*.{yml,yaml,json}]
indent_style = space
indent_size  = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
